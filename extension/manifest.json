{
  "manifest_version": 3,
  "name": "Multi-LLM Prompt Dispatcher",
  "version": "1.1.0",
  "description": "一次输入，多模型网页端并行发送 Prompt，支持 ChatGPT、Claude、Gemini、Grok、DeepSeek、通义千问、豆包、智谱清言、MiniMax、Kimi 等",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://grok.x.ai/*",
    "https://x.com/*",
    "https://chat.deepseek.com/*",
    "https://tongyi.aliyun.com/*",
    "https://qianwen.aliyun.com/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "https://chatglm.cn/*",
    "https://zhipuai.cn/*",
    "https://hailuoai.com/*",
    "https://kimi.moonshot.cn/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://grok.x.ai/*",
        "https://chat.deepseek.com/*",
        "https://tongyi.aliyun.com/*",
        "https://qianwen.aliyun.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://chatglm.cn/*",
        "https://zhipuai.cn/*",
        "https://hailuoai.com/*",
        "https://kimi.moonshot.cn/*"
      ],
      "js": [
        "content/network-interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "content/adapters/base.js",
        "content/adapters/chatgpt.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://grok.x.ai/*",
        "https://chat.deepseek.com/*",
        "https://tongyi.aliyun.com/*",
        "https://qianwen.aliyun.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://chatglm.cn/*",
        "https://zhipuai.cn/*",
        "https://hailuoai.com/*",
        "https://kimi.moonshot.cn/*"
      ],
      "js": [
        "content/bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content/adapters/base.js",
        "content/adapters/claude.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": [
        "content/adapters/base.js",
        "content/adapters/gemini.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      }
    },
    "open-dashboard": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "MacCtrl+Shift+D"
      },
      "description": "打开指挥中心 Dashboard"
    }
  }
}